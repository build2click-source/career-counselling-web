generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      Role      @default(STUDENT)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  attempts  Attempt[]
}

model Assessment {
  id               String             @id @default(uuid())
  title            String
  description      String?
  timeLimitMinutes Int
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  isArchived       Boolean            @default(false)
  modules          AssessmentModule[]
  attempts         Attempt[]
}

model AssessmentModule {
  id           String     @id @default(uuid())
  assessmentId String
  title        String
  type         String
  order        Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  isArchived   Boolean    @default(false)
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questions    Question[]
}

model Question {
  id              String           @id @default(uuid())
  moduleId        String
  text            String
  traitDimension  String?
  scoringPolarity String?
  options         String
  correctAnswer   String?
  marks           Float            @default(1.0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  isArchived      Boolean          @default(false)
  module          AssessmentModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  responses       Response[]
}

model OccupationalProfile {
  id            String         @id @default(uuid())
  title         String         @unique
  description   String
  targetVector  String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  fitmentScores FitmentScore[]
}

model Attempt {
  id            String         @id @default(uuid())
  userId        String
  assessmentId  String
  startTime     DateTime       @default(now())
  endTime       DateTime?
  sessionExpiry DateTime
  isCompleted   Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  assessment    Assessment     @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  fitmentScores FitmentScore[]
  responses     Response[]
}

model Response {
  id         String   @id @default(uuid())
  attemptId  String
  questionId String
  answerText String
  scoreValue Float?
  isCorrect  Boolean?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  attempt    Attempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

model FitmentScore {
  id                    String              @id @default(uuid())
  attemptId             String
  occupationalProfileId String
  euclideanDistance     Float
  fitmentPercentage     Float
  matchedTags           String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  attempt               Attempt             @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  occupationalProfile   OccupationalProfile @relation(fields: [occupationalProfileId], references: [id], onDelete: Cascade)
}

enum Role {
  STUDENT
  ADMIN
}
